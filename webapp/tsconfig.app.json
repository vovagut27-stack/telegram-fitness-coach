{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "es2023",
    "lib": ["ES2023", "DOM"],
    "module": "esnext",
    "types": ["vite/client"],
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "erasableSyntaxOnly": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@shared/exercise-image-catalog": ["../src/services/exercise-image-catalog.ts"],
      "@shared/exercise-photo-urls": ["../src/services/exercise-photo-urls.ts"],
      "@shared/exercise-visual-catalog": ["../src/services/exercise-visual-catalog.ts"],
      "@shared/rep-targets": ["../src/utils/rep-targets.ts"]
    }
  },
  "include": ["src"]
}
