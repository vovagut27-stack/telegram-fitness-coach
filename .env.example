PORT=3000
APP_BASE_URL=https://your-domain.com
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
OPENAI_API_KEY=your_openai_api_key
# Local: postgres://user:pass@localhost:5432/fitbot
# Vercel/Neon: use «Pooled connection» from Neon dashboard (host contains -pooler)
DATABASE_URL=postgres://user:password@localhost:5432/fitbot
TELEGRAM_WEBHOOK_SECRET=replace_me
WEBAPP_URL=https://your-miniapp-domain.com
FREE_WORKOUTS_PER_WEEK=3
# Your Telegram user ID — /myid in the bot. Receives /report messages.
REPORT_TELEGRAM_IDS=
ADMIN_TELEGRAM_IDS=
# External hourly cron → GET /api/cron/reminders (see docs/VERCEL_DEPLOY.md)
CRON_SECRET=
